# [수정] 절대경로 → 상대경로
# Vite proxy(/api → localhost:8000)를 경유하므로 PC·모바일 모두 동일하게 동작
VITE_API_BASE_URL=/api
VITE_OUT_DIR=D:/test/vue-dist

# QR 코드 스캔 URL 베이스 주소
# ngrok 고정 도메인 사용 → 모바일에서 방화벽 우회 및 HTTPS 접속 가능
# ngrok 실행 명령: ngrok http --host-header=rewrite --domain=bottom-gleaming-lather.ngrok-free.dev 5173
VITE_SCAN_BASE_URL=https://bottom-gleaming-lather.ngrok-free.dev