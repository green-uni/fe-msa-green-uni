# [수정] 절대경로 → 상대경로
# Vite proxy(/api → localhost:8000)를 경유하므로 PC·모바일 모두 동일하게 동작
VITE_API_BASE_URL=/api
VITE_OUT_DIR=D:/test/vue-dist

# [추가] QR 코드 안에 들어갈 스캔 URL 베이스 주소
# 교수가 localhost로 접속해도 QR은 모바일이 접근 가능한 네트워크 IP를 사용

# 학원 위치나 PC가 바뀌면 ipconfig로 IPv4 확인 후 이 값만 수정
VITE_SCAN_BASE_URL=https://bottom-gleaming-lather.ngrok-free.dev